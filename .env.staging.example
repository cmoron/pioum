# Configuration STAGING pour déploiement derrière nginx reverse proxy
# Copier vers .env.staging et remplir les valeurs

# === OBLIGATOIRE ===

# Domaine staging (sans https://)
# Exemple: stage.pioum.ovh ou pioum-staging.example.com
STAGING_DOMAIN=stage.pioum.ovh

# Secret JWT (générer avec: openssl rand -hex 32)
# CRITIQUE: Doit être différent de la production
JWT_SECRET=

# Mot de passe PostgreSQL (générer avec: openssl rand -hex 16)
DB_PASSWORD=

# === AUTHENTIFICATION ===

# Google OAuth (recommandé pour staging)
# Utiliser un OAuth client dédié au staging avec redirect URI: https://stage.pioum.ovh/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# === PUSH NOTIFICATIONS ===

# Générer avec: npx web-push generate-vapid-keys
# Convertir la clé privée en JWK: node -e "const d='<PRIVATE_KEY>'; console.log(JSON.stringify({kty:'EC',crv:'P-256',d,key_ops:['sign']}))"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY_JWK=
VAPID_EMAIL=mailto:contact@example.com

# === OPTIONNEL ===

# SMTP pour Magic Link (optionnel en staging)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@mypacer.fr

# Database (valeurs par défaut recommandées)
DB_USER=pioum
DB_NAME=pioum_staging

# === NOTES ===
# - Le SSL/TLS est géré par le nginx hôte, pas par cette stack Docker
# - Les ports ne sont PAS exposés sur l'hôte, seulement sur le réseau Docker interne
# - Le nginx hôte doit être configuré pour faire le proxy vers les containers
