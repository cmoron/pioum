generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(cuid())
  email           String?   @unique
  name            String
  avatarId        String?
  customAvatarUrl String?
  googleId        String?   @unique
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  avatar             Avatar?             @relation(fields: [avatarId], references: [id])
  memberships        GroupMember[]
  cars               Car[]
  participations     Passenger[]
  bansGiven          Ban[]               @relation("BanGiver")
  bansReceived       Ban[]               @relation("BanReceiver")
  magicLinks         MagicLink[]
  userCars           UserCar[]
  recurrencePatterns RecurrencePattern[]
  sessionsCreated    Session[]           @relation("sessionsCreated")
  pushSubscription   PushSubscription?

  @@index([email])
  @@index([googleId])
}

model PushSubscription {
  id           String   @id @default(cuid())
  userId       String   @unique
  endpoint     String   @unique
  p256dh       String
  auth         String
  enabledTypes String[] @default([])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MagicLink {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  email     String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([email])
}

model Avatar {
  id       String  @id @default(cuid())
  name     String
  imageUrl String
  category String?

  users User[]
  userCars UserCar[]
  groups Group[]
}

model Group {
  id         String   @id @default(cuid())
  name       String
  inviteCode String   @unique
  avatarId   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  avatar             Avatar?             @relation(fields: [avatarId], references: [id])
  members            GroupMember[]
  sessions           Session[]
  recurrencePatterns RecurrencePattern[]
  tags               GroupTag[]

  @@index([inviteCode])
}

model GroupTag {
  id        String   @id @default(cuid())
  groupId   String
  label     String
  createdAt DateTime @default(now())

  group         Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  passengerTags PassengerTag[]
  carTags       CarTag[]

  @@unique([groupId, label])
  @@index([groupId])
}

model GroupMember {
  id       String   @id @default(cuid())
  userId   String
  groupId  String
  role     String   @default("member")
  joinedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([groupId])
}

model RecurrencePattern {
  id          String    @id @default(cuid())
  groupId     String
  createdById String
  startTime   String    // Time of day HH:mm format
  endTime     String    // Time of day HH:mm format
  daysOfWeek  Int[]     // 0=Sunday, 1=Monday, ..., 6=Saturday
  startDate   DateTime  @db.Date
  endDate     DateTime? @db.Date
  createdAt   DateTime  @default(now())

  group     Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdBy User      @relation(fields: [createdById], references: [id], onDelete: Cascade)
  sessions  Session[]

  @@index([groupId])
}

model Session {
  id                   String   @id @default(cuid())
  groupId              String
  date                 DateTime @db.Date
  startTime            DateTime
  endTime              DateTime
  recurrencePatternId  String?
  createdById          String?
  createdAt            DateTime @default(now())

  group             Group              @relation(fields: [groupId], references: [id], onDelete: Cascade)
  recurrencePattern RecurrencePattern? @relation(fields: [recurrencePatternId], references: [id], onDelete: SetNull)
  createdBy         User?              @relation("sessionsCreated", fields: [createdById], references: [id], onDelete: SetNull)
  cars              Car[]
  passengers        Passenger[]

  @@unique([groupId, startTime])
  @@index([groupId, date])
  @@index([groupId, startTime])
  @@index([recurrencePatternId])
}

model Car {
  id        String  @id @default(cuid())
  sessionId String
  driverId  String
  seats     Int
  userCarId String?

  session    Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  driver     User        @relation(fields: [driverId], references: [id], onDelete: Cascade)
  userCar    UserCar?    @relation(fields: [userCarId], references: [id], onDelete: SetNull)
  passengers Passenger[]
  tags       CarTag[]

  @@unique([sessionId, driverId])
  @@index([sessionId])
  @@index([userCarId])
}

model CarTag {
  id         String  @id @default(cuid())
  carId      String
  groupTagId String?
  freeText   String?

  car      Car       @relation(fields: [carId], references: [id], onDelete: Cascade)
  groupTag GroupTag? @relation(fields: [groupTagId], references: [id], onDelete: Cascade)

  @@index([carId])
}

model Passenger {
  id        String   @id @default(cuid())
  sessionId String
  userId    String
  carId     String?
  joinedAt  DateTime @default(now())

  session Session        @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  car     Car?           @relation(fields: [carId], references: [id], onDelete: SetNull)
  tags    PassengerTag[]

  @@unique([sessionId, userId])
  @@index([sessionId])
  @@index([carId])
}

model PassengerTag {
  id          String  @id @default(cuid())
  passengerId String
  groupTagId  String?
  freeText    String?

  passenger Passenger @relation(fields: [passengerId], references: [id], onDelete: Cascade)
  groupTag  GroupTag? @relation(fields: [groupTagId], references: [id], onDelete: Cascade)

  @@index([passengerId])
}

model Ban {
  id         String    @id @default(cuid())
  giverId    String
  receiverId String
  reason     String?
  startsAt   DateTime  @default(now())
  endsAt     DateTime
  liftedAt   DateTime?
  createdAt  DateTime  @default(now())

  giver    User @relation("BanGiver", fields: [giverId], references: [id], onDelete: Cascade)
  receiver User @relation("BanReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([giverId, receiverId])
  @@index([receiverId, endsAt])
}

model UserCar {
  id            String   @id @default(cuid())
  userId        String
  name          String?
  avatarId      String
  defaultSeats  Int      @default(3)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  avatar      Avatar @relation(fields: [avatarId], references: [id])
  sessionCars Car[]

  @@index([userId])
}
